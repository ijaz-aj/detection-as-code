# ── Elastic lab stack configuration ──────────────────────────────────────────
# Copy this file to `.env` (in this lab/ folder) and change the passwords.
# `.env` is gitignored and must never be committed.
#
#   cp .env.example .env      # then edit the passwords below
#
# These are LOCAL LAB credentials only — never reuse a real/personal password.

# Version of the Elastic stack (Elasticsearch, Kibana, Elastic Agent).
STACK_VERSION=8.15.3

# Cluster + license
CLUSTER_NAME=dac-lab
LICENSE=basic                 # 'basic' (free) or 'trial' (30-day, unlocks Security features)

# Passwords (min 6 chars). CHANGE THESE.
ELASTIC_PASSWORD=changeme_elastic
KIBANA_PASSWORD=changeme_kibana

# 32+ char key used by Kibana to encrypt saved objects. CHANGE THIS.
# Generate one with:  openssl rand -hex 32
ENCRYPTION_KEY=c34d38b3a14956121ff2170e5030b471551370178f43e5626eec58b04a30fae2

# Host ports exposed to your machine (and to the lab VM via the host-only network)
ES_PORT=9200
KIBANA_PORT=5601
FLEET_PORT=8220

# Container memory limits (bytes). Tuned for a 16 GB host running a VM alongside.
#   ES 2 GiB, Kibana 1 GiB, Fleet Server 1 GiB
ES_MEM_LIMIT=2147483648
KB_MEM_LIMIT=1073741824
FLEET_MEM_LIMIT=1073741824
