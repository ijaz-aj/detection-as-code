(process.pe.original_file_name:(Cmd.Exe OR PowerShell.EXE OR pwsh.dll OR wscript.exe OR cscript.exe OR MSHTA.EXE OR RUNDLL32.EXE OR REGSVR32.EXE OR CertUtil.exe)) AND (NOT ((process.pe.original_file_name:Cmd.Exe AND process.executable:*\\cmd.exe) OR (process.pe.original_file_name:PowerShell.EXE AND process.executable:*\\powershell.exe) OR (process.pe.original_file_name:pwsh.dll AND process.executable:*\\pwsh.exe) OR (process.pe.original_file_name:wscript.exe AND process.executable:*\\wscript.exe) OR (process.pe.original_file_name:cscript.exe AND process.executable:*\\cscript.exe) OR (process.pe.original_file_name:MSHTA.EXE AND process.executable:*\\mshta.exe) OR (process.pe.original_file_name:RUNDLL32.EXE AND process.executable:*\\rundll32.exe) OR (process.pe.original_file_name:REGSVR32.EXE AND process.executable:*\\regsvr32.exe) OR (process.pe.original_file_name:CertUtil.exe AND process.executable:*\\certutil.exe)))
