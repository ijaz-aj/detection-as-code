OriginalFileName IN ("Cmd.Exe", "PowerShell.EXE", "pwsh.dll", "wscript.exe", "cscript.exe", "MSHTA.EXE", "RUNDLL32.EXE", "REGSVR32.EXE", "CertUtil.exe") NOT ((OriginalFileName="Cmd.Exe" Image="*\\cmd.exe") OR (OriginalFileName="PowerShell.EXE" Image="*\\powershell.exe") OR (OriginalFileName="pwsh.dll" Image="*\\pwsh.exe") OR (OriginalFileName="wscript.exe" Image="*\\wscript.exe") OR (OriginalFileName="cscript.exe" Image="*\\cscript.exe") OR (OriginalFileName="MSHTA.EXE" Image="*\\mshta.exe") OR (OriginalFileName="RUNDLL32.EXE" Image="*\\rundll32.exe") OR (OriginalFileName="REGSVR32.EXE" Image="*\\regsvr32.exe") OR (OriginalFileName="CertUtil.exe" Image="*\\certutil.exe"))
