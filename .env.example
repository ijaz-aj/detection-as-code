# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.
#
# Used by the Phase 5 phishing / IOC triage tool. All tools also support a
# `--demo` mode that runs with mocked data and requires NO keys.

# VirusTotal API key — https://www.virustotal.com/gui/my-apikey (free tier available)
VT_API_KEY=

# URLScan.io API key — https://urlscan.io/user/profile/ (free tier available)
URLSCAN_API_KEY=
